{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["react", "typescript", "unicorn", "oxc"],
  // sonarjs gives cognitive-complexity; oxlint-plugin-eslint exposes ESLint's
  // built-in rules (aliased to `eslint-js` since `eslint` is native) so we can
  // use no-restricted-syntax to ban `let`.
  "jsPlugins": ["eslint-plugin-sonarjs", { "name": "eslint-js", "specifier": "oxlint-plugin-eslint" }],
  "categories": { "correctness": "error" },
  "rules": {
    "max-lines": ["error", { "max": 400, "skipBlankLines": true, "skipComments": true }],
    "max-lines-per-function": ["error", { "max": 120, "skipBlankLines": true, "skipComments": true }],
    "max-depth": ["error", { "max": 4 }],
    "max-params": ["error", { "max": 5 }],
    "max-nested-callbacks": ["error", { "max": 4 }],
    "react/rules-of-hooks": "error",
    "react/exhaustive-deps": "error",
    "sonarjs/cognitive-complexity": ["error", 15],
    "sonarjs/no-identical-functions": "error",
    "sonarjs/no-duplicated-branches": "error",
    "sonarjs/no-identical-conditions": "error",
    "sonarjs/no-identical-expressions": "error",
    "sonarjs/no-gratuitous-expressions": "error",
    "sonarjs/no-duplicate-string": "error",
    "no-var": "error",
    "no-param-reassign": "error",
    "eqeqeq": ["error", "smart"],
    "typescript/no-non-null-assertion": "error",
    "typescript/no-explicit-any": "error",
    "eslint-js/no-restricted-syntax": [
      "error",
      {
        "selector": "VariableDeclaration[kind=let]",
        "message": "`let` is banned (const-first). Extract a value-returning function, or use a const accumulator object (mutating its fields is fine)."
      },
      {
        "selector": "TSAsExpression:not([typeAnnotation.typeName.name=\"const\"])",
        "message": "Type assertion `as` is banned (`as const` is allowed). Use a type guard, `satisfies`, or fix the types instead."
      }
    ]
  },
  "overrides": [
    {
      "files": ["**/*.tsx"],
      "rules": {
        "max-lines-per-function": "off"
      }
    },
    {
      // Known-large legacy containers — grandfathered above the 400 default.
      // Ratchet these down over time; new files must stay under 400.
      "files": ["src/web/App.tsx", "src/web/components/Timeline.tsx"],
      "rules": {
        "max-lines": ["error", { "max": 560, "skipBlankLines": true, "skipComments": true }]
      }
    },
    {
      "files": ["test/**", "e2e/**"],
      "rules": {
        "max-lines": "off",
        "max-lines-per-function": "off",
        // Tests legitimately repeat selectors and assertion literals; inline
        // values read clearer than extracted constants.
        "sonarjs/no-duplicate-string": "off"
      }
    }
  ]
}
