{
  "name": "agtail",
  "version": "0.1.0",
  "description": "Cross-agent forensic search for coding-agent histories (Claude Code, Codex). Search-first; read-only.",
  "type": "module",
  "bin": {
    "agtail": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "dist-web"
  ],
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.6.0",
  "scripts": {
    "build:web": "vite build",
    "build:node": "tsup",
    "build": "pnpm build:web && pnpm build:node",
    "dev:web": "vite",
    "dev:cli": "tsx src/cli/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint && biome lint src/web/styles",
    "lint:fix": "oxlint --fix && biome lint --write src/web/styles",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "depcruise": "depcruise src",
    "knip": "knip",
    "check": "pnpm typecheck && pnpm lint && pnpm depcruise && pnpm knip && pnpm format:check && pnpm test",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "react-virtuoso": "^4.18.7"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.13.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.3",
    "dependency-cruiser": "^18.0.0",
    "eslint-plugin-sonarjs": "4.1.0",
    "knip": "^6.21.0",
    "oxlint": "1.71.0",
    "oxlint-plugin-eslint": "1.71.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
